            </div>
            <div class="contact-item-text">
              <span class="contact-item-label">Phone</span>
              <a class="contact-item-value" href="tel:01772497772">01772 497772</a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="#C4956A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
