<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bonbons Coffee Bar – Penwortham</title>
  <meta name="description" content="An atmospheric coffee bar and village tea rooms in the heart of Penwortham. Quality coffee, specialty teas, homemade cakes, breakfasts, light lunches and afternoon teas." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <style>
    /* ─── PALETTE ─────────────────────────────────────────────
       Espresso   #1C0A00
       Dark roast #3B1A08
       Mid brown  #6B3421
       Caramel    #A0622A
       Gold       #C4956A
       Cream      #F5E6D3
       Ivory      #FDF6EE
    ──────────────────────────────────────────────────────── */

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --espresso:  #1C0A00;
      --dark:      #3B1A08;
      --mid:       #6B3421;
      --caramel:   #A0622A;
      --gold:      #C4956A;
      --cream:     #F5E6D3;
      --ivory:     #FDF6EE;
      --white:     #FFFFFF;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background: var(--ivory);
      color: var(--dark);
      overflow-x: hidden;
    }

    /* ─── TYPOGRAPHY ─────────────────────────────────────── */
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; line-height: 1.15; }

    /* ─── NAV ─────────────────────────────────────────────── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
      height: 72px;
      background: var(--espresso);
      border-bottom: 2px solid var(--caramel);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--cream);
      letter-spacing: 0.04em;
      text-decoration: none;
    }

    .nav-logo span { color: var(--gold); }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Lato', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--cream);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }

    .nav-cta {
      background: var(--caramel);
      color: var(--ivory) !important;
      padding: 8px 20px;
      border-radius: 2px;
      transition: background 0.2s !important;
    }

    .nav-cta:hover { background: var(--gold) !important; color: var(--espresso) !important; }

    /* ─── HERO ────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      background: var(--espresso);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* decorative circles */
    .hero::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      border: 1px solid rgba(196,149,106,0.15);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
    }

    .hero::after {
      content: '';
      position: absolute;
      width: 900px; height: 900px;
      border-radius: 50%;
      border: 1px solid rgba(196,149,106,0.08);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
    }

    /* coffee bean pattern overlay */
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(ellipse 3px 5px at 15% 20%, rgba(107,52,33,0.3) 0%, transparent 100%),
        radial-gradient(ellipse 3px 5px at 80% 70%, rgba(107,52,33,0.3) 0%, transparent 100%),
        radial-gradient(ellipse 3px 5px at 60% 15%, rgba(107,52,33,0.2) 0%, transparent 100%),
        radial-gradient(ellipse 3px 5px at 30% 80%, rgba(107,52,33,0.2) 0%, transparent 100%);
    }

    /* warm glow */
    .hero-glow {
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(107,52,33,0.35) 0%, transparent 70%);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 0 24px;
      max-width: 820px;
    }

    .hero-eyebrow {
      display: inline-block;
      font-family: 'Lato', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
    }

    .hero-eyebrow::before,
    .hero-eyebrow::after {
      content: '—';
      margin: 0 10px;
      opacity: 0.6;
    }

    .hero h1 {
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 800;
      font-style: italic;
      color: var(--cream);
      line-height: 1.05;
      margin-bottom: 28px;
    }

    .hero h1 em {
      font-style: normal;
      color: var(--gold);
    }

    .hero-tagline {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1rem, 2vw, 1.3rem);
      font-style: italic;
      color: rgba(245,230,211,0.75);
      margin-bottom: 48px;
      line-height: 1.7;
    }

    .hero-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-block;
      background: var(--caramel);
      color: var(--ivory);
      font-family: 'Lato', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 16px 36px;
      border-radius: 2px;
      transition: background 0.25s, transform 0.2s;
    }

    .btn-primary:hover { background: var(--gold); color: var(--espresso); transform: translateY(-2px); }

    .btn-ghost {
      display: inline-block;
      border: 1px solid rgba(196,149,106,0.5);
      color: var(--cream);
      font-family: 'Lato', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 16px 36px;
      border-radius: 2px;
      transition: border-color 0.25s, background 0.25s;
    }

    .btn-ghost:hover { border-color: var(--gold); background: rgba(196,149,106,0.1); }

    .hero-scroll {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      z-index: 2;
    }

    .hero-scroll span {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(196,149,106,0.5);
    }

    .scroll-line {
      width: 1px;
      height: 48px;
      background: linear-gradient(to bottom, rgba(196,149,106,0.5), transparent);
      animation: scrollPulse 2s ease-in-out infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; }
      50%       { opacity: 1; }
    }

    /* ─── STRIP ───────────────────────────────────────────── */
    .strip {
      background: var(--caramel);
      padding: 16px 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
    }

    .strip-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--ivory);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .strip-item svg { opacity: 0.9; }

    /* ─── ABOUT ───────────────────────────────────────────── */
    .about {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 600px;
    }

    .about-visual {
      background: var(--dark);
      position: relative;
      overflow: hidden;
      min-height: 500px;
    }

    .about-visual-inner {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, var(--espresso) 0%, var(--dark) 40%, var(--mid) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .about-cup {
      position: relative;
      width: 200px;
      height: 200px;
    }

    /* SVG cup illustration */
    .about-visual-inner svg {
      width: 260px;
      height: 260px;
      opacity: 0.85;
    }

    .about-rings {
      position: absolute;
      inset: 0;
    }

    .about-rings circle {
      fill: none;
      stroke: rgba(196,149,106,0.12);
    }

    .about-content {
      background: var(--cream);
      padding: 80px 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .section-label {
      font-family: 'Lato', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--caramel);
      margin-bottom: 18px;
    }

    .about-content h2 {
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--espresso);
      margin-bottom: 24px;
      line-height: 1.15;
    }

    .about-content p {
      font-size: 1.05rem;
      line-height: 1.9;
      color: var(--mid);
      margin-bottom: 20px;
    }

    .about-content p strong { color: var(--espresso); }

    .about-divider {
      width: 60px;
      height: 2px;
      background: var(--gold);
      margin: 28px 0;
    }

    /* ─── MENU ────────────────────────────────────────────── */
    .menu {
      background: var(--espresso);
      padding: 100px 48px;
    }

    .section-header {
      text-align: center;
      margin-bottom: 64px;
    }

    .section-header h2 {
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      color: var(--cream);
      margin-bottom: 16px;
    }

    .section-header p {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.1rem;
      color: var(--gold);
    }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .menu-card {
      background: var(--dark);
      padding: 48px 36px;
      text-align: center;
      border: 1px solid rgba(196,149,106,0.1);
      transition: background 0.3s, border-color 0.3s;
      cursor: default;
    }

    .menu-card:hover {
      background: var(--mid);
      border-color: rgba(196,149,106,0.35);
    }

    .menu-icon {
      font-size: 2.4rem;
      margin-bottom: 20px;
      display: block;
    }

    .menu-card h3 {
      font-size: 1.3rem;
      color: var(--cream);
      margin-bottom: 14px;
    }

    .menu-card p {
      font-size: 0.9rem;
      line-height: 1.8;
      color: rgba(245,230,211,0.65);
    }

    .menu-card .tag {
      display: inline-block;
      margin-top: 20px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(196,149,106,0.4);
      padding: 4px 12px;
      border-radius: 1px;
    }

    /* ─── AFTERNOON TEA FEATURE ───────────────────────────── */
    .feature {
      background: var(--dark);
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 520px;
    }

    .feature-content {
      padding: 80px 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .feature-content h2 {
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--cream);
      margin-bottom: 20px;
    }

    .feature-content p {
      font-size: 1.05rem;
      line-height: 1.85;
      color: rgba(245,230,211,0.7);
      margin-bottom: 16px;
    }

    .feature-visual {
      background: var(--mid);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .feature-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--mid) 0%, var(--caramel) 100%);
    }

    .feature-pattern {
      position: absolute;
      inset: 0;
      opacity: 0.07;
      background-image: repeating-linear-gradient(
        45deg,
        var(--cream) 0,
        var(--cream) 1px,
        transparent 0,
        transparent 50%
      );
      background-size: 20px 20px;
    }

    .feature-visual-text {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 48px;
    }

    .feature-visual-text .big-num {
      font-family: 'Playfair Display', serif;
      font-size: 8rem;
      font-weight: 800;
      line-height: 1;
      color: rgba(245,230,211,0.1);
      display: block;
    }

    .feature-visual-text h3 {
      font-size: 1.8rem;
      font-style: italic;
      color: var(--cream);
      margin-top: -20px;
    }

    .feature-visual-text p {
      margin-top: 16px;
      font-size: 0.85rem;
      color: rgba(245,230,211,0.6);
      line-height: 1.8;
      letter-spacing: 0.03em;
    }

    /* ─── VISIT ───────────────────────────────────────────── */
    .visit {
      background: var(--ivory);
      padding: 100px 48px;
    }

    .visit-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .visit h2 {
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--espresso);
      margin-bottom: 16px;
    }

    .visit > .visit-inner > div > p {
      font-size: 1.05rem;
      line-height: 1.85;
      color: var(--mid);
      margin-bottom: 32px;
    }

    .contact-block {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 16px;
    }

    .contact-icon {
      width: 42px;
      height: 42px;
      border-radius: 2px;
      background: var(--espresso);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-icon svg { width: 18px; height: 18px; }

    .contact-item-text {
      display: flex;
      flex-direction: column;
    }

    .contact-item-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--caramel);
      margin-bottom: 4px;
    }

    .contact-item-value {
      font-size: 1rem;
      color: var(--espresso);
      text-decoration: none;
      font-weight: 600;
    }

    .contact-item-value:hover { color: var(--caramel); }

    /* map placeholder */
    .map-box {
      background: var(--dark);
      border-radius: 2px;
      overflow: hidden;
      position: relative;
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .map-box iframe {
      width: 100%;
      height: 100%;
      border: 0;
      filter: sepia(40%) contrast(1.1);
    }

    /* ─── SOCIAL ──────────────────────────────────────────── */
    .social {
      background: var(--cream);
      padding: 80px 48px;
      text-align: center;
    }

    .social h2 {
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      color: var(--espresso);
      margin-bottom: 12px;
    }

    .social > p {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.1rem;
      color: var(--mid);
      margin-bottom: 40px;
    }

    .social-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .social-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 32px;
      border-radius: 2px;
      text-decoration: none;
      font-family: 'Lato', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: transform 0.2s, opacity 0.2s;
    }

    .social-btn:hover { transform: translateY(-3px); opacity: 0.9; }

    .social-btn-fb {
      background: #1877F2;
      color: #fff;
    }

    .social-btn-ig {
      background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
      color: #fff;
    }

    .social-hint {
      font-size: 0.8rem;
      color: var(--caramel);
      letter-spacing: 0.05em;
    }

    /* ─── FOOTER ──────────────────────────────────────────── */
    footer {
      background: var(--espresso);
      padding: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 24px;
      border-top: 2px solid rgba(196,149,106,0.2);
    }

    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--cream);
      letter-spacing: 0.04em;
    }

    .footer-logo span { color: var(--gold); }

    .footer-center {
      text-align: center;
    }

    .footer-center p {
      font-size: 0.78rem;
      color: rgba(245,230,211,0.4);
      letter-spacing: 0.06em;
    }

    .footer-social {
      display: flex;
      gap: 14px;
    }

    .footer-social a {
      width: 38px;
      height: 38px;
      border: 1px solid rgba(196,149,106,0.3);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--gold);
      text-decoration: none;
      font-size: 1rem;
      transition: background 0.2s, border-color 0.2s;
    }

    .footer-social a:hover {
      background: rgba(196,149,106,0.15);
      border-color: var(--gold);
    }

    /* ─── RESPONSIVE ──────────────────────────────────────── */
    @media (max-width: 900px) {
      nav { padding: 0 24px; }
      .nav-links { display: none; }
      .about { grid-template-columns: 1fr; }
      .about-visual { min-height: 300px; }
      .about-content { padding: 60px 32px; }
      .feature { grid-template-columns: 1fr; }
      .feature-content { padding: 60px 32px; }
      .visit-inner { grid-template-columns: 1fr; }
      footer { flex-direction: column; align-items: center; text-align: center; }
    }

    @media (max-width: 600px) {
      .strip { flex-direction: column; gap: 12px; }
      .menu { padding: 60px 24px; }
      .visit { padding: 60px 24px; }
      .social { padding: 60px 24px; }
      footer { padding: 36px 24px; }
    }
  </style>
</head>
<body>

  <!-- ── NAV ───────────────────────────────────────────── -->
  <nav aria-label="Main navigation">
    <a href="#" class="nav-logo">Bon<span>bons</span></a>
    <ul class="nav-links">
      <li><a href="#about">Our Story</a></li>
      <li><a href="#menu">Menu</a></li>
      <li><a href="#afternoon-tea">Afternoon Tea</a></li>
      <li><a href="#visit">Find Us</a></li>
      <li><a href="#social" class="nav-cta">Follow Us</a></li>
    </ul>
  </nav>

  <!-- ── HERO ──────────────────────────────────────────── -->
  <section class="hero" aria-label="Welcome">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      <span class="hero-eyebrow">Est. Penwortham</span>
      <h1>Where friends<br/>meet &amp; hearts<br/><em>warm.</em></h1>
      <p class="hero-tagline">
        An atmospheric coffee bar and village tea rooms<br/>
        in the heart of Penwortham, Preston.
      </p>
      <div class="hero-buttons">
        <a href="#menu" class="btn-primary">Explore the Menu</a>
        <a href="#visit" class="btn-ghost">Find Us</a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ── STRIP ─────────────────────────────────────────── -->
  <div class="strip" aria-label="Highlights">
    <div class="strip-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
      Quality Coffee
    </div>
    <div class="strip-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/><circle cx="12" cy="12" r="3"/></svg>
      Specialty Teas
    </div>
    <div class="strip-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Homemade Cakes
    </div>
    <div class="strip-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
      Private Events
    </div>
    <div class="strip-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      Regular Giveaways
    </div>
  </div>

  <!-- ── ABOUT ──────────────────────────────────────────── -->
  <section class="about" id="about">
    <div class="about-visual" aria-hidden="true">
      <div class="about-visual-inner">
        <svg viewBox="0 0 260 260" xmlns="http://www.w3.org/2000/svg" fill="none">
          <!-- saucer -->
          <ellipse cx="130" cy="195" rx="70" ry="14" fill="rgba(196,149,106,0.2)" stroke="rgba(196,149,106,0.5)" stroke-width="1.5"/>
          <!-- cup body -->
          <path d="M85 120 Q82 185 130 192 Q178 185 175 120 Z" fill="rgba(107,52,33,0.6)" stroke="rgba(196,149,106,0.6)" stroke-width="1.5"/>
          <!-- cup top -->
          <ellipse cx="130" cy="120" rx="45" ry="9" fill="rgba(196,149,106,0.15)" stroke="rgba(196,149,106,0.5)" stroke-width="1.5"/>
          <!-- coffee surface -->
          <ellipse cx="130" cy="122" rx="38" ry="7" fill="rgba(28,10,0,0.8)"/>
          <!-- latte art swirl -->
          <path d="M118 122 Q124 116 130 122 Q136 128 142 122" stroke="rgba(245,230,211,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="130" cy="122" r="3" fill="rgba(245,230,211,0.3)"/>
          <!-- handle -->
          <path d="M175 135 Q198 135 198 160 Q198 185 175 180" stroke="rgba(196,149,106,0.6)" stroke-width="2" fill="none" stroke-linecap="round"/>
          <!-- steam -->
          <path d="M112 108 Q108 95 112 82" stroke="rgba(245,230,211,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M130 105 Q126 90 130 75" stroke="rgba(245,230,211,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M148 108 Q152 95 148 82" stroke="rgba(245,230,211,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <!-- decorative rings -->
          <circle cx="130" cy="145" r="90" stroke="rgba(196,149,106,0.06)" stroke-width="1"/>
          <circle cx="130" cy="145" r="115" stroke="rgba(196,149,106,0.04)" stroke-width="1"/>
        </svg>
      </div>
    </div>
    <div class="about-content">
      <p class="section-label">Our Story</p>
      <h2>A warm welcome, every single visit.</h2>
      <div class="about-divider"></div>
      <p>
        Tucked into the heart of <strong>Penwortham village</strong>, Bonbons is more than just a coffee bar — it's a place where conversations linger, friendships deepen, and every cup is made with intention.
      </p>
      <p>
        We serve <strong>quality coffee and specialty teas</strong> alongside homemade cakes, hearty breakfasts and light lunches — all in an atmosphere that feels equal parts stylish and unhurried.
      </p>
      <p>
        Whether you're catching up with friends, hosting a business meeting, or simply treating yourself — Bonbons is your corner of calm in Preston.
      </p>
      <a href="#visit" class="btn-primary" style="align-self:flex-start; margin-top: 12px;">Come and see us</a>
    </div>
  </section>

  <!-- ── MENU ───────────────────────────────────────────── -->
  <section class="menu" id="menu" aria-labelledby="menu-heading">
    <div class="section-header">
      <p class="section-label" style="color:var(--gold);">What we serve</p>
      <h2 id="menu-heading">Good food, great coffee.</h2>
      <p>Made fresh. Served with care.</p>
    </div>

    <div class="menu-grid">
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">☕</span>
        <h3>Espresso &amp; Coffee</h3>
        <p>From classic flat whites and lattes to single-origin pour overs — every cup crafted to order.</p>
        <span class="tag">Signature Roasts</span>
      </div>
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">🍵</span>
        <h3>Specialty Teas</h3>
        <p>A curated selection of loose-leaf and blended teas, served properly, the way they deserve to be.</p>
        <span class="tag">Loose Leaf</span>
      </div>
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">🍳</span>
        <h3>Breakfasts</h3>
        <p>Full English, eggs your way, and toasted options — the perfect start to any morning.</p>
        <span class="tag">Served All Morning</span>
      </div>
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">🥗</span>
        <h3>Light Lunches</h3>
        <p>Seasonal soups, freshly filled sandwiches, and daily specials made with local ingredients.</p>
        <span class="tag">Daily Specials</span>
      </div>
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">🎂</span>
        <h3>Homemade Cakes</h3>
        <p>Baked in-house and displayed proudly — changing regularly, gone when they're gone.</p>
        <span class="tag">Baked Fresh Daily</span>
      </div>
      <div class="menu-card">
        <span class="menu-icon" aria-hidden="true">🥂</span>
        <h3>Afternoon Tea</h3>
        <p>Tiered stands, finger sandwiches, warm scones and prosecco — the full, glorious affair.</p>
        <span class="tag">With or Without Prosecco</span>
      </div>
    </div>
  </section>

  <!-- ── AFTERNOON TEA FEATURE ──────────────────────────── -->
  <section class="feature" id="afternoon-tea" aria-labelledby="aft-heading">
    <div class="feature-content">
      <p class="section-label" style="color:var(--gold);">The Full Experience</p>
      <h2 id="aft-heading">Afternoon Tea, done properly.</h2>
      <div class="about-divider"></div>
      <p>
        Bonbons' afternoon tea is an occasion in itself. Think delicate finger sandwiches, warm scones with clotted cream and jam, and a tower of homemade cakes — all served on beautiful tiered stands.
      </p>
      <p>
        Choose to elevate it further with a glass of <strong style="color:var(--gold)">chilled prosecco</strong> and make an afternoon of it. Perfect for birthdays, hen parties, celebrations or just because.
      </p>
      <a href="tel:01772497772" class="btn-primary" style="align-self:flex-start; margin-top:8px;">Book by phone</a>
    </div>
    <div class="feature-visual" aria-hidden="true">
      <div class="feature-pattern"></div>
      <div class="feature-visual-text">
        <span class="big-num">AT</span>
        <h3>Afternoon Tea</h3>
        <p>
          Finger sandwiches · Warm scones<br/>
          Homemade cakes · Specialty teas<br/>
          <em style="color:var(--cream); opacity:0.9;">+ Prosecco if you please</em>
        </p>
      </div>
    </div>
  </section>

  <!-- ── VISIT ──────────────────────────────────────────── -->
