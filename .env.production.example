# =============================================================================
#  Production environment template — Coolify
# -----------------------------------------------------------------------------
#  Copy these keys into Coolify's "Environment Variables" panel and fill in
#  real values. Do NOT commit a filled-in copy of this file.
#
#  Keys marked [BUILD] must also be available at image build time (Coolify
#  exposes build-time variables separately) — Vite bakes them into the bundle.
# =============================================================================

APP_NAME="Bonbons Coffee Bar"
APP_ENV=production
APP_KEY=                                  # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.example       # the domain Coolify serves

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ─────────────────────────────────────────────────────────────────
# stderr so Coolify's log viewer captures everything.
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database — point at the MariaDB/MySQL service created in Coolify ────────
DB_CONNECTION=mysql
DB_HOST=                                  # internal hostname of the DB service
DB_PORT=3306
DB_DATABASE=bonbons
DB_USERNAME=
DB_PASSWORD=

# ── Sessions / cache / queue — all DB-backed (no Redis required) ───────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ── Reverse proxy — trust Coolify/Traefik so https:// URLs are generated ───
TRUSTED_PROXIES=*

# ── Inertia SSR — supervisor runs the Node SSR server inside the container ─
INERTIA_SSR_ENABLED=true
INERTIA_SSR_URL=http://127.0.0.1:13714

# ── Filesystem — S3 keeps uploads off the container (no persistent volume) ─
# Switch to `local` only if you mount /var/www/html/storage/app as a volume.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=                           # set for S3-compatible providers (R2, MinIO…)

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="hello@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

# ── Error monitoring (sentry/sentry-laravel is installed) ──────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Build-time ──────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"               # [BUILD]
